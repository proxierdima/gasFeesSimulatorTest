# Harness core
HARNESS_ADAPTER_MODE=command
HARNESS_OUTPUT_DIR=artifacts
HARNESS_DEFAULT_NETWORK=bradbury
HARNESS_DEFAULT_WAIT_STATUS=finalized
HARNESS_DEFAULT_DEBUG=on-fail
HARNESS_POLL_INTERVAL_SECONDS=0.75
HARNESS_TIMEOUT_SECONDS=90
HARNESS_RANDOM_SEED=42
HARNESS_RPC_URL=https://rpc-bradbury.genlayer.com
HARNESS_PRIVATE_KEY=
HARNESS_COMMAND_RETRIES=4
HARNESS_COMMAND_RETRY_BACKOFF_SECONDS=1.5
HARNESS_TRACE_ROUND=0
HARNESS_VERBOSE=1
HARNESS_PRINT_LOGS=1

# Gas thresholds for preset profiles
HARNESS_GAS_FAIL_BELOW=40
HARNESS_GAS_BORDERLINE_BELOW=65
HARNESS_GAS_NORMAL=90
HARNESS_GAS_HIGH=140

# Test contract wiring
GLH_AUTO_DEPLOY=1
GLH_TEST_CONTRACT_FILE=contracts/fixtures/sample_contract.py
GLH_TEST_CONTRACT_ADDRESS=
GLH_TEST_STATE_READ_FN=get_value
GLH_TEST_WRITE_FN=set_value
GLH_TEST_INVALID_FN=fail

# Command adapter templates
HARNESS_CMD_SUBMIT_WRITE=python scripts/submit_write.py --rpc {rpc_url_sh} --contract {contract_address_sh} --fn {function_name_sh} --args {args_json_sh} --gaslimit {gaslimit}
HARNESS_CMD_SUBMIT_DEPLOY=python scripts/submit_deploy.py --rpc {rpc_url_sh} --contract-file {contract_file_sh} --constructor-args {args_json_sh} --gaslimit {gaslimit}
HARNESS_CMD_STATUS=python scripts/get_status.py --rpc {rpc_url_sh} --tx {tx_hash_sh}
HARNESS_CMD_RECEIPT=python scripts/get_receipt.py --rpc {rpc_url_sh} --tx {tx_hash_sh}
HARNESS_CMD_TRACE=python scripts/get_trace.py --rpc {rpc_url_sh} --tx {tx_hash_sh}
HARNESS_CMD_READ_STATE=python scripts/read_state.py --rpc {rpc_url_sh} --contract {contract_address_sh} --fn {function_name_sh} --args {args_json_sh}

# Leave empty to use the official genlayer CLI automatically in helper scripts
GLH_SUBMIT_WRITE_BACKEND_CMD=
GLH_SUBMIT_DEPLOY_BACKEND_CMD=
GLH_READ_STATE_BACKEND_CMD=
